#!/usr/bin/env bash
#
# Hermes Desktop UI — Launch script
# Usage: hermes-desktop-ui [start|build|status|help]
#
# Launches the Flutter-based Hermes Agent desktop management UI.
# Reads Hermes config/sessions/skills/logs from ~/.hermes/
# and connects to the Gateway API Server at localhost:8642.
#

set -e

APP_NAME="Hermes Desktop UI"
SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
PROJECT_DIR="$(cd "$SCRIPT_DIR/.." && pwd)"

# --- Detect OS ---
case "$(uname -s)" in
    Linux*)     OS=linux; EXECUTABLE="hermes_desktop";;
    Darwin*)    OS=macos; EXECUTABLE="hermes_desktop";;
    CYGWIN*|MINGW*|MSYS*) OS=windows; EXECUTABLE="hermes_desktop.exe";;
    *)          OS=unknown; EXECUTABLE="";;
esac

BUILD_DIR="$PROJECT_DIR/build/$OS/x64/release"
EXEC_PATH="$BUILD_DIR/$EXECUTABLE"

# --- Colors ---
RED='\033[0;31m'
GREEN='\033[0;32m'
YELLOW='\033[1;33m'
BLUE='\033[0;34m'
NC='\033[0m'

info()  { echo -e "${BLUE}ℹ${NC} $1"; }
ok()    { echo -e "${GREEN}✓${NC} $1"; }
warn()  { echo -e "${YELLOW}⚠${NC} $1"; }
err()   { echo -e "${RED}✗${NC} $1"; }

# --- Health check: is Gateway running? ---
check_gateway() {
    if curl -sf http://localhost:8642/health > /dev/null 2>&1; then
        ok "Hermes Gateway 在线 (localhost:8642)"
        return 0
    else
        warn "Hermes Gateway 未运行 — 部分功能不可用"
        info "启动方式: hermes gateway run (或在 ~/.hermes/.env 添加 API_SERVER_ENABLED=true)"
        return 1
    fi
}

# --- Start ---
cmd_start() {
    echo ""
    echo "  ╔══════════════════════════════╗"
    echo "  ║   Hermes Desktop UI v1.0.0  ║"
    echo "  ╚══════════════════════════════╝"
    echo ""

    check_gateway || true

    if [ ! -f "$EXEC_PATH" ]; then
        warn "未找到已编译的应用: $EXEC_PATH"
        info "正在尝试构建..."
        cmd_build
    fi

    if [ -f "$EXEC_PATH" ]; then
        ok "启动 $APP_NAME ..."
        "$EXEC_PATH" &
        PID=$!
        echo "PID: $PID"
        info "按 Ctrl+C 停止"
        wait $PID
    else
        err "构建失败，无法启动"
        info "请先在 Windows 终端执行: cd $PROJECT_DIR && flutter build windows --release"
        exit 1
    fi
}

# --- Build ---
cmd_build() {
    info "检查 Flutter SDK..."
    if ! command -v flutter &> /dev/null; then
        if [ "$OS" = "windows" ]; then
            err "Flutter 未安装或不在 PATH 中"
            info "请安装 Flutter: https://docs.flutter.dev/get-started/install/windows"
            info "或在 Windows 终端执行: cd $PROJECT_DIR && flutter build windows --release"
            exit 1
        fi
    fi

    info "构建 $APP_NAME ($OS release)..."
    cd "$PROJECT_DIR"
    flutter build $OS --release 2>&1 || {
        err "构建失败。确保 Flutter SDK 已安装并配置正确"
        info "详情运行: flutter doctor"
        exit 1
    }
    ok "构建完成: $EXEC_PATH"
}

# --- Status ---
cmd_status() {
    echo ""
    echo "  Hermes Desktop UI — 状态检查"
    echo "  ================================="
    echo ""

    # Check binary
    if [ -f "$EXEC_PATH" ]; then
        ok "应用已构建: $EXEC_PATH"
    else
        warn "应用尚未构建"
        info "运行: hermes-desktop-ui build"
    fi

    # Check gateway
    check_gateway || true

    # Check Hermes home
    HERMES_HOME="${HOME}/.hermes"
    if [ -d "$HERMES_HOME" ]; then
        ok "Hermes 目录: $HERMES_HOME"
        SESSION_COUNT=$(ls "$HERMES_HOME/sessions/" 2>/dev/null | wc -l)
        SKILL_COUNT=$(find "$HERMES_HOME/skills/" -name "SKILL.md" 2>/dev/null | wc -l)
        info "会话文件: $SESSION_COUNT"
        info "已安装技能: $SKILL_COUNT"
    else
        warn "Hermes 目录不存在: $HERMES_HOME"
    fi
}

# --- Help ---
cmd_help() {
    echo ""
    echo "  Hermes Desktop UI"
    echo ""
    echo "  用法: hermes-desktop-ui <命令>"
    echo ""
    echo "  命令:"
    echo "    start      启动桌面管理面板"
    echo "    build      构建 release 版本"
    echo "    status     检查运行状态"
    echo "    help       显示此帮助"
    echo ""
    echo "  示例:"
    echo "    hermes-desktop-ui start"
    echo "    hermes-desktop-ui build"
    echo "    hermes-desktop-ui status"
    echo ""
}

# --- Main ---
case "${1:-help}" in
    start)   cmd_start;;
    build)   cmd_build;;
    status)  cmd_status;;
    help|--help|-h) cmd_help;;
    *)
        err "未知命令: $1"
        cmd_help
        exit 1
        ;;
esac
